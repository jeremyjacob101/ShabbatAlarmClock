    <string name="alerts_notifications_title">הפעלת התראות</string>
    <string name="alerts_notifications_message">Shabbat Alarm Clock משתמשת בהתראות כדי להפעיל שעוני מעורר בזמן שנקבע. הפעילו התראות עכשיו כדי שהשעוני המעורר יצלצלו.</string>
    <string name="alerts_notifications_request_failed">לא ניתן היה לבקש הרשאת התראות. בדקו את ההגדרות ונסו שוב.</string>
    <string name="alerts_notifications_not_allowed">לא אושרו התראות. עדיין אפשר לשמור שעוני מעורר, אבל הם לא יצלצלו עד שההתראות יופעלו.</string>
    <string name="alerts_notifications_saved_but_disabled">השעון המעורר נשמר, אבל ההתראות לא מופעלות. הפעילו אותן בהגדרות כדי להפעיל שעוני מעורר.</string>
    <string name="alerts_notifications_saved_but_request_failed">השעון המעורר נשמר, אבל לא ניתן היה לבקש הרשאת התראות. בדקו את ההגדרות כדי להפעיל שעוני מעורר.</string>
    <string name="alerts_notifications_disabled_for_enable">ההתראות לא מופעלות. הפעילו אותן בהגדרות כדי להפעיל שעוני מעורר.</string>
    <string name="alerts_notifications_enable_failed">לא ניתן היה להפעיל את השעון המעורר כי לא ניתן היה לבקש הרשאת התראות. בדקו את ההגדרות ונסו שוב.</string>
    <string name="alerts_notifications_schedule_failed">לא ניתן היה לתזמן את השעון המעורר. בדקו את הגדרות ההתראות ונסו שוב.</string>

